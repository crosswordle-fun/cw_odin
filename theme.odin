		highlight_fragment_shadow = TAILWIND_BLUE_700,
		highlight_rune = TAILWIND_PURPLE_500,
		highlight_rune_shadow = TAILWIND_PURPLE_700,
		exp = TAILWIND_YELLOW_500,
		wordle_correct = TAILWIND_GREEN_500,
		wordle_present = TAILWIND_YELLOW_500,
		wordle_miss = TAILWIND_GRAY_400,
		wordle_empty = TAILWIND_GRAY_200,
		button_fill = TAILWIND_BLACK,
		button_shadow = TAILWIND_GRAY_300,
		button_text = TAILWIND_BLACK,
