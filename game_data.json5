    level_exp_reward: 100,
    board_y: 125,
    level_y: 92,
    reward_exp_y: 360,
    reward_burst_count: 24,
    win_title: "CONGRATULATIONS!",
    win_subtitle: "PUZZLE SOLVED. YOUR REWARD IS READY.",
    rewards_label: "REWARDS",
    level_label_prefix: "LEVEL",
  },

  crafting: {
    selection_capacity: 5,
    matching_required: 4,
    random_required: 5,
    exp_reward: 250,
    fragment_label: "FRAGMENTS",
    incomplete_label: "INCOMPLETE RECIPE",
    matching_label: "MATCHING RUNE",
    random_label: "RANDOM RUNE",
    latest_rune_label: "LATEST RUNE",
    board_y: 204,
    reward_exp_y: 410,
    reward_burst_count: 22,
  },

  effects: {
    view_transition_duration: 0.34,
    exp_pulse_duration: 0.42,
    exp_pulse_frequency: 22,
    invalid_shake_duration: 0.34,
    invalid_shake_frequency: 92,
    floating_text_lifetime: 1.2,
    floating_text_rise: 44,
    exp_burst_count: 18,
    tile_pop_duration: 0.5,
  },

  themes: [
    {
      background: [243, 244, 246, 255],
      canvas: [0, 0, 0, 255],
      text: [0, 0, 0, 255],
      text_inverted: [255, 255, 255, 255],
      text_muted: [0, 0, 0, 255],
      outline: [0, 0, 0, 255],
      surface: [229, 231, 235, 255],
      surface_shadow: [153, 161, 175, 255],
      empty_tile: [229, 231, 235, 255],
      highlight_fragment: [81, 162, 255, 255],
      highlight_fragment_shadow: [43, 127, 255, 255],
      highlight_rune: [194, 122, 255, 255],
      highlight_rune_shadow: [173, 70, 255, 255],
      exp: [0, 0, 0, 255],
      wordle_correct: [5, 223, 114, 255],
      wordle_present: [240, 177, 0, 255],
      wordle_miss: [153, 161, 175, 255],
      wordle_empty: [229, 231, 235, 255],
      button_fill: [74, 85, 101, 255],
